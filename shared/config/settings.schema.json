{
  "default_format": {
    "type": "string",
    "allowed": ["zip", "7z", "tar.gz"],
    "default": "zip"
  },
  "language": {
    "type": "string",
    "allowed": ["ko", "en", "ja"],
    "default": "system"
  },
  "split_size_mb": {
    "type": "integer",
    "minimum": 0,
    "default": 0
  },
  "output_conflict_policy": {
    "type": "string",
    "allowed": ["append", "overwrite", "ask"],
    "default": "append"
  },
  "drag_overlay_dock_side": {
    "type": "string",
    "allowed": ["left", "right"],
    "default": "left"
  }
}
