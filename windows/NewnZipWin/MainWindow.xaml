<Window
    x:Class="NewnZipWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="newnZip">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Text="newnZip" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="파일, 폴더, 압축파일을 빠르게 압축하거나 해제합니다." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                x:Name="DropSurface"
                AllowDrop="True"
                MinHeight="220"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                DragOver="DropSurfaceDragOver"
                Drop="DropSurfaceDrop">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                <FontIcon Glyph="&#xE8B7;" FontSize="44" />
                <TextBlock x:Name="StatusText"
                           Text="우클릭 메뉴 또는 파일 연결로 실행할 준비가 됐습니다."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="420" />
                <ProgressRing x:Name="ProgressRing" IsActive="False" Width="36" Height="36" />
            </StackPanel>
        </Border>

        <Border x:Name="SettingsPanel"
                Grid.Row="2"
                Visibility="Collapsed"
                Padding="14"
                Margin="0,0,0,12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="8">
                <ToggleSwitch x:Name="DefaultArchiveToggle"
                              Header="기본 압축 앱으로 사용"
                              Toggled="DefaultArchiveToggleToggled" />
                <TextBlock x:Name="DefaultArchiveStatusText"
                           Text="현재 기본 앱 상태를 확인 중입니다."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
                <ComboBox x:Name="ConflictPolicyBox"
                          Header="같은 이름 결과 처리"
                          SelectionChanged="ConflictPolicySelectionChanged">
                    <ComboBoxItem Content="사본으로 추가" Tag="Append" />
                    <ComboBoxItem Content="덮어쓰기" Tag="Overwrite" />
                    <ComboBoxItem Content="항상 물어보기" Tag="Ask" />
                </ComboBox>
                <PasswordBox x:Name="ArchivePasswordBox"
                             Header="압축 암호 (생성/해제 공용)"
                             PasswordChanged="ArchivePasswordBoxPasswordChanged" />
                <ToggleSwitch x:Name="DragOverlayToggle"
                              Header="드래그 오버레이 표시"
                              Toggled="DragOverlayToggleToggled" />
                <ComboBox x:Name="DragOverlayDockSideBox"
                          Header="드래그 오버레이 붙는 위치"
                          SelectionChanged="DragOverlayDockSideSelectionChanged">
                    <ComboBoxItem Content="왼쪽" Tag="Left" />
                    <ComboBoxItem Content="오른쪽" Tag="Right" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="DetailText"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="ZIP 생성/해제는 내장 엔진을 사용합니다." />
            <Button Grid.Column="1" Click="OpenSettingsClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" />
                    <TextBlock Text="설정" />
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Click="CloseClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8BB;" />
                    <TextBlock Text="닫기" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
