<Window
    x:Class="NewnZipWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="newnZip">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Text="newnZip" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="파일, 폴더, 압축파일을 빠르게 압축하거나 해제합니다." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                MinHeight="220"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                <FontIcon Glyph="&#xE8B7;" FontSize="44" />
                <TextBlock x:Name="StatusText"
                           Text="우클릭 메뉴 또는 파일 연결로 실행할 준비가 됐습니다."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="420" />
                <ProgressRing x:Name="ProgressRing" IsActive="False" Width="36" Height="36" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="DetailText"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="ZIP 생성/해제는 내장 엔진을 사용합니다." />
            <Button Grid.Column="1" Click="OpenSettingsClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" />
                    <TextBlock Text="설정" />
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Click="CloseClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8BB;" />
                    <TextBlock Text="닫기" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
