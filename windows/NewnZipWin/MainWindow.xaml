<Window
    x:Class="NewnZipWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="newnZip">

    <Grid x:Name="RootGrid" Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Text="newnZip" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="파일, 폴더, 압축파일을 빠르게 압축하거나 해제합니다." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="1" MinHeight="220" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <Border x:Name="DropSurface"
                    AllowDrop="True"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    DragOver="DropSurfaceDragOver"
                    Drop="DropSurfaceDrop"
                    Tapped="DropSurfaceTapped">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                    <FontIcon Glyph="&#xE8B7;" FontSize="44" />
                    <TextBlock x:Name="StatusText"
                               Text="우클릭 메뉴 또는 파일 연결로 실행할 준비가 됐습니다."
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="420" />
                    <ProgressRing x:Name="ProgressRing" IsActive="False" Width="36" Height="36" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="PasswordDropSurface"
                        AllowDrop="True"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        DragOver="PasswordDropSurfaceDragOver"
                        Drop="PasswordDropSurfaceDrop"
                        Tapped="PasswordDropSurfaceTapped">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE72E;" FontSize="24" />
                        <TextBlock Text="암호로 압축"
                                   TextAlignment="Center"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="드래그 또는 클릭"
                                   TextAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        x:Name="SplitDropSurface"
                        AllowDrop="True"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        DragOver="SplitDropSurfaceDragOver"
                        Drop="SplitDropSurfaceDrop"
                        Tapped="SplitDropSurfaceTapped">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE8C1;" FontSize="24" />
                        <TextBlock Text="분할 압축"
                                   TextAlignment="Center"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="드래그 또는 클릭"
                                   TextAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border x:Name="SettingsPanel"
                Grid.Row="2"
                Visibility="Collapsed"
                Padding="14"
                Margin="0,0,0,12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="GeneralSettingsTabButton"
                                Click="GeneralSettingsTabButtonClick"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE713;" FontSize="22" />
                                <TextBlock Text="일반" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="CompressionSettingsTabButton"
                                Grid.Column="1"
                                Click="CompressionSettingsTabButtonClick"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7B8;" FontSize="22" />
                                <TextBlock Text="압축" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="OverlaySettingsTabButton"
                                Grid.Column="2"
                                Click="OverlaySettingsTabButtonClick"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7C5;" FontSize="22" />
                                <TextBlock Text="오버레이" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border
                        x:Name="GeneralSettingsSection"
                        Padding="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="일반" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="중복 결과 처리와 기본 앱 상태를 관리합니다."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <ComboBox x:Name="ConflictPolicyBox"
                                      Header="같은 이름 결과 처리"
                                      SelectionChanged="ConflictPolicySelectionChanged">
                                <ComboBoxItem Content="사본으로 추가" Tag="Append" />
                                <ComboBoxItem Content="덮어쓰기" Tag="Overwrite" />
                                <ComboBoxItem Content="항상 물어보기" Tag="Ask" />
                            </ComboBox>
                            <ToggleSwitch x:Name="DefaultArchiveToggle"
                                          Header="기본 압축 앱으로 사용"
                                          Toggled="DefaultArchiveToggleToggled" />
                            <TextBlock x:Name="DefaultArchiveStatusText"
                                       Text="현재 기본 앱 상태를 확인 중입니다."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="CompressionSettingsSection"
                        Padding="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="압축" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="암호와 분할 압축 기본값을 미리 저장합니다."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <PasswordBox x:Name="ArchivePasswordBox"
                                         Header="압축 암호"
                                         PasswordChanged="ArchivePasswordBoxPasswordChanged"
                                         PasswordRevealMode="Visible" />
                            <TextBox x:Name="DefaultSplitSizeBox"
                                     Header="기본 분할 용량 MB"
                                     TextChanged="DefaultSplitSizeBoxTextChanged" />
                            <TextBox x:Name="DefaultSplitPartCountBox"
                                     Header="기본 분할 개수"
                                     TextChanged="DefaultSplitPartCountBoxTextChanged" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="OverlaySettingsSection"
                        Padding="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="오버레이" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="전역 드래그 오버레이 표시 여부와 붙는 위치를 정합니다."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <ToggleSwitch x:Name="DragOverlayToggle"
                                          Header="드래그 오버레이 표시"
                                          Toggled="DragOverlayToggleToggled" />
                            <ComboBox x:Name="DragOverlayDockSideBox"
                                      Header="드래그 오버레이 붙는 위치"
                                      SelectionChanged="DragOverlayDockSideSelectionChanged">
                                <ComboBoxItem Content="왼쪽" Tag="Left" />
                                <ComboBoxItem Content="오른쪽" Tag="Right" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="DetailText"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="ZIP 생성/해제는 내장 엔진을 사용합니다." />
            <Button Grid.Column="1" Click="OpenSettingsClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" />
                    <TextBlock Text="설정" />
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Click="CloseClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8BB;" />
                    <TextBlock Text="닫기" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
